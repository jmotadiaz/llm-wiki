{
  "name": "@llm-wiki/server",
  "version": "1.0.0",
  "description": "Express backend for LLM Wiki",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc && cp ../.env dist/ && mkdir -p dist/llm/prompts && cp src/llm/prompts/*.md dist/llm/prompts/",
    "start": "cd dist && node index.js"
  },
  "dependencies": {
    "@ai-sdk/deepinfra": "^2.0.45",
    "@openrouter/ai-sdk-provider": "^2.5.1",
    "ai": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.21.0",
    "typescript": "^6.0.0"
  }
}
